{
  "name": "@sapo-presentation/sapo-ui-components",
  "version": "1.6.18-alpha.20",
  "license": "ISC",
  "main": "build/index.js",
  "module": "build/index.es.js",
  "types": "build/index.d.ts",
  "files": [
    "build"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run lint:fix",
      "git add ."
    ]
  },
  "scripts": {
    "start": "start-storybook -p 6006",
    "build": "npx rollup -c",
    "build:storybook": "build-storybook -c .storybook",
    "check": "npm run type-check",
    "type-check": "tsc --skipLibCheck --noEmit",
    "lint": "eslint --ext js,jsx,ts,tsx src",
    "lint:quiet": "eslint --quiet --ext js,jsx,ts,tsx src",
    "lint:fix": "eslint --fix --ext js,jsx,ts,tsx src",
    "clean": "npx rimraf build",
    "clean:svg": "npx rimraf src/assets/svgr",
    "clean:svg:index": "npx rimraf src/assets/svgr/index.tsx",
    "convert-svg": "npm run clean:svg && npx @svgr/cli --typescript -d src/assets/svgr src/assets --config-file src/assets/svgr-config.json --template src/assets/svg-template.js && npm run clean:svg:index"
  },
  "publishConfig": {
    "@sapo-presentation:registry": "https://git.dktsoft.com/api/v4/projects/2357/packages/npm/"
  },
  "peerDependencies": {
    "@types/react": "^16.8.6",
    "lodash": ">=4.17.15",
    "moment": ">=2.24.0",
    "react": ">=16.8.4",
    "react-dom": ">=16.8.4",
    "styled-components": ">=5.3.5"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
